---
layout: layouts/base.njk
---
<article class="noticia container section">
  <a class="noticia__volver" href="/noticias/">&larr; Volver a noticias</a>

  <div class="noticia__portada">
    {% if portada %}
      <img src="{{ portada }}" alt="{{ titulo }}">
    {% else %}
      <div class="noticia__portada-placeholder">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="3" y="4" width="18" height="16" rx="1.5" fill="none" stroke="currentColor" stroke-width="1.6"/>
          <line x1="6.5" y1="8" x2="17.5" y2="8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
          <line x1="6.5" y1="11.5" x2="17.5" y2="11.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
          <line x1="6.5" y1="15" x2="13" y2="15" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
        <span>{{ titulo }}</span>
      </div>
    {% endif %}
  </div>

  <p class="noticia__fecha">{{ fecha | fechaLarga }}</p>
  <h1 class="noticia__titulo">{{ titulo }}</h1>

  <div class="noticia__cuerpo">
    {{ content | safe }}
  </div>
</article>
