---
layout: layouts/base.njk
title: MEE Cuenta · Chivita
description: Chivita, el robot guía del proyecto MEE Cuenta, te muestra el patrimonio de Illapel.
---

<!-- ===== 1. HERO ===== -->
<section class="hero container">
  <span class="hero__pill">{{ landing.hero.pildora }}</span>

  <img src="/assets/img/logo-chivita.svg" alt="Chivita, robot de MEE Cuenta" class="hero-logo">

  <h1 class="hero__title">{{ site.nombre_experiencia }}</h1>
  <p class="hero__slogan">{{ site.slogan }}</p>

  <div class="hero__speech">
    <p>{{ landing.hero.presentacion }}</p>
  </div>
</section>

<!-- ===== 2. ¿QUÉ ES CHIVITA? ===== -->
<section class="section que-es container">
  <p class="section__eyebrow">El proyecto</p>
  <h2 class="section__title">{{ landing.que_es.titulo }}</h2>
  {% for parrafo in landing.que_es.parrafos %}
    <p>{{ parrafo }}</p>
  {% endfor %}
</section>

<!-- ===== 3. ¿CÓMO FUNCIONA? ===== -->
<section class="section section--salvia">
  <div class="container">
    <p class="section__eyebrow">Paso a paso</p>
    <h2 class="section__title">¿Cómo funciona?</h2>
    <ul class="steps">
      {% for paso in pasos.items %}
        <li class="step">
          <span class="step__num">{{ paso.numero }}</span>
          <div>
            <h3 class="step__titulo">{{ paso.titulo }}</h3>
            <p class="step__texto">{{ paso.texto }}</p>
          </div>
        </li>
      {% endfor %}
    </ul>
  </div>
</section>

<!-- ===== 4. TECNOLOGÍA ===== -->
<section class="section container">
  <p class="section__eyebrow">Bajo el capó</p>
  <h2 class="section__title">Tecnología</h2>
  <ul class="tech-grid">
    {% for tech in tecnologias.items %}
      <li class="tech-card">
        <span class="tech-card__nombre">{{ tech.nombre }}</span>
        <span class="tech-card__rol">{{ tech.rol }}</span>
      </li>
    {% endfor %}
  </ul>
</section>

<!-- ===== 5. ¿POR QUÉ IMPORTA? ===== -->
<section class="section section--marino">
  <div class="container">
    <p class="section__eyebrow">El impacto</p>
    <h2 class="section__title">{{ landing.por_que_importa.titulo }}</h2>
    <ul class="why-grid">
      {% for item in landing.por_que_importa.items %}
        <li class="why-card">
          <h3 class="why-card__titulo">{{ item.titulo }}</h3>
          <p class="why-card__texto">{{ item.texto }}</p>
        </li>
      {% endfor %}
    </ul>
  </div>
</section>
